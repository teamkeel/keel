model Account {
    fields {
        email Text
    }

    actions {
        create createAccount() {
            @set(account.email = ctx.identity.email)
        }
        update updateAccount(id) {
            @set(account.email = ctx.identity.email)
        }
        list listAccounts()
        get getAccount() {
            @where(account.id == "123")
        }
        delete deleteAccount() {
            @where(account.id == "123")
        }
    }
}

api Test {
    models {
        Account
    }
}